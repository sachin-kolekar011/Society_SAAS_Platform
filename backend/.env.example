NODE_ENV=development
PORT=4000

# MySQL connection string for Prisma
DATABASE_URL="mysql://user:password@localhost:3306/society_saas"

# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be two DIFFERENT values.
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me_differently

ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12

# Cloudinary (Phase 9 - complaint photo uploads)
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AI complaint triage - "keyword" (default, free) or "llm" (needs an Anthropic API key, see triage/llmTriage.js)
TRIAGE_PROVIDER=keyword

# Razorpay (billing module - test mode keys from the Razorpay dashboard)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (Phase 9 - notifications)
APP_NAME="Society SaaS"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
