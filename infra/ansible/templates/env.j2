NODE_ENV=production
PORT=4000

DATABASE_URL="mysql://{{ db_username }}:{{ db_password }}@{{ rds_endpoint }}/{{ db_name }}"

JWT_ACCESS_SECRET={{ jwt_access_secret }}
JWT_REFRESH_SECRET={{ jwt_refresh_secret }}
ACCESS_TOKEN_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

BCRYPT_SALT_ROUNDS=12
APP_NAME="{{ app_name | default('Society SaaS') }}"

STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME={{ cloudinary_cloud_name }}
CLOUDINARY_API_KEY={{ cloudinary_api_key }}
CLOUDINARY_API_SECRET={{ cloudinary_api_secret }}

TRIAGE_PROVIDER=keyword

RAZORPAY_KEY_ID={{ razorpay_key_id | default('') }}
RAZORPAY_KEY_SECRET={{ razorpay_key_secret | default('') }}

SMTP_HOST={{ smtp_host }}
SMTP_PORT={{ smtp_port | default(587) }}
SMTP_USER={{ smtp_user }}
SMTP_PASS={{ smtp_pass }}
